# ==========================================
# MemeMaker Backend — Variables d'environnement
# ==========================================

# Serveur
PORT=3000
NODE_ENV=development

# ─── Google AI Studio (Gemini) ────────────────────────────────────────────────
# Obtenir sur : https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ─── Upload ───────────────────────────────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=10
